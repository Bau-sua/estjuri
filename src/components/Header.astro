---
const navLinks = [
  { href: "#servicios", label: "Servicios" },
  { href: "#equipo", label: "Equipo" },
  { href: "#testimonios", label: "Testimonios" },
  { href: "#faq", label: "FAQ" },
];
---

<header
  id="header"
  class="fixed top-0 left-0 right-0 z-50 bg-background/80 backdrop-blur-md border-b border-border/50 transition-shadow"
>
  <nav class="container-main flex items-center justify-between h-16 md:h-20">
    <a href="/" class="flex items-center gap-2 no-underline group" aria-label="Inicio">
      <span
        class="font-heading text-xl md:text-2xl font-bold text-primary tracking-tight"
      >
        ESTJURI
      </span>
      <span
        class="hidden sm:inline-block w-1.5 h-1.5 rounded-full bg-accent group-hover:scale-125 transition-transform"
      ></span>
    </a>

    <!-- Desktop nav -->
    <ul class="hidden md:flex items-center gap-8 text-sm font-medium text-muted-foreground">
      {
        navLinks.map((link) => (
          <li>
            <a
              href={link.href}
              class="hover:text-foreground transition-colors duration-200"
            >
              {link.label}
            </a>
          </li>
        ))
      }
    </ul>

    <a
      href="#contacto"
      class="hidden md:inline-flex items-center px-5 py-2.5 rounded-lg bg-primary text-white text-sm font-semibold
             hover:bg-primary-light active:scale-[0.98] transition-all duration-200 shadow-sm hover:shadow-md"
    >
      Consultar
    </a>

    <!-- Mobile hamburger -->
    <button
      id="mobile-toggle"
      class="md:hidden flex flex-col gap-1.5 p-2"
      aria-label="Abrir menú"
      aria-expanded="false"
    >
      <span class="block w-5 h-0.5 bg-foreground rounded transition-transform origin-center"></span>
      <span class="block w-5 h-0.5 bg-foreground rounded transition-opacity"></span>
      <span class="block w-5 h-0.5 bg-foreground rounded transition-transform origin-center"></span>
    </button>
  </nav>

  <!-- Mobile menu -->
  <div
    id="mobile-menu"
    class="md:hidden hidden border-t border-border bg-background"
  >
    <div class="container-main py-4 flex flex-col gap-3">
      {
        navLinks.map((link) => (
          <a
            href={link.href}
            class="py-2 text-sm font-medium text-muted-foreground hover:text-foreground transition-colors"
          >
            {link.label}
          </a>
        ))
      }
      <a
        href="#contacto"
        class="mt-2 inline-flex items-center justify-center px-5 py-2.5 rounded-lg bg-primary text-white text-sm font-semibold
               hover:bg-primary-light active:scale-[0.98] transition-all"
      >
        Consultar
      </a>
    </div>
  </div>
</header>
