<section id="contacto" class="section-padding bg-muted/50">
  <div class="container-main">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16">
      <!-- Left: info + form -->
      <div>
        <div class="accent-line"></div>
        <h2 class="text-3xl sm:text-4xl md:text-5xl font-heading font-bold text-foreground tracking-tight text-balance">
          Consultanos sin compromiso
        </h2>
        <p class="mt-4 text-base md:text-lg text-muted-foreground leading-relaxed">
          Completá el formulario y nos pondremos en contacto en menos de 24 horas
          hábiles para coordinar una consulta inicial.
        </p>

        <form
          class="mt-8 space-y-5"
          name="contacto"
          method="POST"
          data-netlify="true"
          netlify-honeypot="bot-field"
        >
          <input type="hidden" name="form-name" value="contacto" />
          <p class="hidden">
            <label>No llenar: <input name="bot-field" /></label>
          </p>

          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div>
              <label for="nombre" class="block text-sm font-medium text-foreground mb-1.5">
                Nombre
              </label>
              <input
                type="text"
                id="nombre"
                name="nombre"
                required
                class="w-full rounded-lg border border-border bg-white px-4 py-2.5 text-sm text-foreground placeholder:text-muted-foreground/50
                       focus:outline-none focus:ring-2 focus:ring-primary/20 focus:border-primary/40 transition"
                placeholder="Tu nombre"
              />
            </div>
            <div>
              <label for="email" class="block text-sm font-medium text-foreground mb-1.5">
                Email
              </label>
              <input
                type="email"
                id="email"
                name="email"
                required
                class="w-full rounded-lg border border-border bg-white px-4 py-2.5 text-sm text-foreground placeholder:text-muted-foreground/50
                       focus:outline-none focus:ring-2 focus:ring-primary/20 focus:border-primary/40 transition"
                placeholder="tu@email.com"
              />
            </div>
          </div>

          <div>
            <label for="telefono" class="block text-sm font-medium text-foreground mb-1.5">
              Teléfono
            </label>
            <input
              type="tel"
              id="telefono"
              name="telefono"
              class="w-full rounded-lg border border-border bg-white px-4 py-2.5 text-sm text-foreground placeholder:text-muted-foreground/50
                     focus:outline-none focus:ring-2 focus:ring-primary/20 focus:border-primary/40 transition"
              placeholder="+54 11 1234-5678"
            />
          </div>

          <div>
            <label for="area" class="block text-sm font-medium text-foreground mb-1.5">
              Área de consulta
            </label>
            <select
              id="area"
              name="area"
              class="w-full rounded-lg border border-border bg-white px-4 py-2.5 text-sm text-foreground
                     focus:outline-none focus:ring-2 focus:ring-primary/20 focus:border-primary/40 transition"
            >
              <option value="">Seleccionar área</option>
              <option value="familia">Derecho de Familia</option>
              <option value="laboral">Derecho Laboral</option>
              <option value="sucesiones">Sucesiones</option>
              <option value="comercial">Derecho Comercial</option>
              <option value="otro">Otro</option>
            </select>
          </div>

          <div>
            <label for="mensaje" class="block text-sm font-medium text-foreground mb-1.5">
              Contanos brevemente tu caso
            </label>
            <textarea
              id="mensaje"
              name="mensaje"
              rows="4"
              required
              class="w-full rounded-lg border border-border bg-white px-4 py-2.5 text-sm text-foreground placeholder:text-muted-foreground/50
                     focus:outline-none focus:ring-2 focus:ring-primary/20 focus:border-primary/40 transition resize-y"
              placeholder="Describí tu situación en pocas palabras..."
            ></textarea>
          </div>

          <button
            type="submit"
            class="w-full sm:w-auto inline-flex items-center justify-center px-8 py-3.5 rounded-lg bg-primary text-white text-base font-semibold
                   hover:bg-primary-light active:scale-[0.98] transition-all duration-200 shadow-lg shadow-primary/20 hover:shadow-xl"
          >
            Enviar consulta
            <svg class="ml-2 w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"/>
            </svg>
          </button>
        </form>
      </div>

      <!-- Right: contact details + map placeholder -->
      <div class="space-y-10">
        <!-- Contact cards -->
        <div class="space-y-5">
          <div class="flex items-start gap-4">
            <div class="w-10 h-10 flex items-center justify-center rounded-lg bg-primary/5 text-primary shrink-0">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a2 2 0 01-2.828 0l-4.243-4.243a8 8 0 1111.314 0z"/>
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
              </svg>
            </div>
            <div>
              <h4 class="text-sm font-semibold text-foreground">Dirección</h4>
              <p class="mt-1 text-sm text-muted-foreground leading-relaxed">
                Av. Ejemplo 1234, Piso 5°<br/>
                CABA, Buenos Aires<br/>
                Argentina
              </p>
            </div>
          </div>

          <div class="flex items-start gap-4">
            <div class="w-10 h-10 flex items-center justify-center rounded-lg bg-primary/5 text-primary shrink-0">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
              </svg>
            </div>
            <div>
              <h4 class="text-sm font-semibold text-foreground">Teléfono</h4>
              <p class="mt-1 text-sm text-muted-foreground">+54 11 1234-5678</p>
            </div>
          </div>

          <div class="flex items-start gap-4">
            <div class="w-10 h-10 flex items-center justify-center rounded-lg bg-primary/5 text-primary shrink-0">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
              </svg>
            </div>
            <div>
              <h4 class="text-sm font-semibold text-foreground">Email</h4>
              <p class="mt-1 text-sm text-muted-foreground">contacto@estjuri.com.ar</p>
            </div>
          </div>

          <div class="flex items-start gap-4">
            <div class="w-10 h-10 flex items-center justify-center rounded-lg bg-primary/5 text-primary shrink-0">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
              </svg>
            </div>
            <div>
              <h4 class="text-sm font-semibold text-foreground">Horarios</h4>
              <p class="mt-1 text-sm text-muted-foreground">
                Lunes a Viernes<br/>
                09:00 – 18:00 hs
              </p>
            </div>
          </div>
        </div>

        <!-- Map placeholder -->
        <!--<div class="aspect-video rounded-xl bg-muted-dark flex items-center justify-center border border-border overflow-hidden">
          <div class="text-center text-muted-foreground">
            <svg class="w-10 h-10 mx-auto mb-2 opacity-40" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7"/>
            </svg>
            <p class="text-sm">Mapa de ubicación</p>
            <p class="text-xs mt-1 opacity-60">Av. Ejemplo 1234, CABA</p>
          </div>--->
        </div>
      </div>
    </div>
  </div>
</section>
