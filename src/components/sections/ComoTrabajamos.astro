---
const pasos = [
  {
    paso: "01",
    titulo: "Consulta inicial",
    descripcion:
      "Escuchamos tu situación en detalle, analizamos la viabilidad de tu caso y te explicamos las opciones disponibles. Sin compromiso y con total confidencialidad.",
  },
  {
    paso: "02",
    titulo: "Estrategia legal",
    descripcion:
      "Diseñamos un plan de acción personalizado, evaluando cada alternativa y su posible resultado. Te mantenemos informado para que tomes decisiones con seguridad.",
  },
  {
    paso: "03",
    titulo: "Resolución efectiva",
    descripcion:
      "Ejecutamos la estrategia con determinación y te acompañamos hasta el resultado final. Nuestro compromiso no termina hasta que tu caso esté resuelto.",
  },
];
---

<section class="section-padding bg-primary-dark text-white relative overflow-hidden">
  <!-- Decorative -->
  <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
    <div class="absolute top-0 right-0 w-[500px] h-[500px] bg-white/3 rounded-full blur-3xl -translate-y-1/2 translate-x-1/3"></div>
  </div>

  <div class="container-main relative z-10">
    <div class="max-w-2xl">
      <div class="accent-line"></div>
      <h2 class="text-3xl sm:text-4xl md:text-5xl font-heading font-bold text-white tracking-tight text-balance">
        Cómo trabajamos
      </h2>
      <p class="mt-4 text-base md:text-lg text-white/60 leading-relaxed">
        Un proceso claro, simple y transparente. Tres pasos para pasar de la
        incertidumbre a la solución.
      </p>
    </div>

    <!-- Steps -->
    <div class="mt-12 md:mt-16 grid grid-cols-1 md:grid-cols-3 gap-8 md:gap-6">
      {
        pasos.map((p, i) => (
          <div class="relative group">
            <!-- Connector line between cards (desktop) -->
            {i < pasos.length - 1 && (
              <div class="hidden md:block absolute top-11 left-full w-6 h-px bg-white/10" aria-hidden="true"></div>
            )}
            <!-- Step number -->
            <span class="font-heading text-5xl md:text-6xl font-bold text-white/10 group-hover:text-accent/30 transition-colors">
              {p.paso}
            </span>
            <h3 class="mt-3 text-xl font-heading font-semibold text-white">
              {p.titulo}
            </h3>
            <p class="mt-2 text-sm md:text-base text-white/50 leading-relaxed">
              {p.descripcion}
            </p>
          </div>
        ))
      }
    </div>
  </div>
</section>
