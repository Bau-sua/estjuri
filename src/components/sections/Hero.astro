<section
  class="relative min-h-screen flex items-center bg-background overflow-hidden"
>
  <!-- Decorative background elements -->
  <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
    <div class="absolute top-20 right-0 w-[600px] h-[600px] bg-muted rounded-full blur-3xl opacity-40 -translate-y-1/2 translate-x-1/4"></div>
    <div class="absolute bottom-0 left-0 w-[400px] h-[400px] bg-primary/5 rounded-full blur-3xl opacity-30 translate-y-1/3 -translate-x-1/4"></div>
  </div>

  <div class="container-main relative z-10 pt-24 pb-16 md:pt-28 md:pb-20">
    <div class="max-w-3xl">
      <!-- Trust badge -->
      <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-primary/5 border border-primary/10 text-xs font-medium text-primary mb-8">
        <span class="w-1.5 h-1.5 rounded-full bg-accent"></span>
        Estudio jurídico en Buenos Aires
      </div>

      <!-- Headline -->
      <h1 class="text-4xl sm:text-5xl md:text-6xl lg:text-7xl font-heading font-bold text-foreground tracking-tight text-balance leading-[1.08]">
        Defendemos tus derechos
        <span class="text-primary">con precisión</span>
        <span class="text-accent">.</span>
      </h1>

      <!-- Subheadline -->
      <p class="mt-6 md:mt-8 text-base sm:text-lg md:text-xl text-muted-foreground leading-relaxed max-w-xl text-balance">
        Asesoramiento legal de excelencia con un enfoque cercano, transparente y
        estratégico. Convertimos tus problemas legales en soluciones efectivas.
      </p>

      <!-- CTAs -->
      <div class="mt-8 md:mt-10 flex flex-col sm:flex-row gap-4">
        <a
          href="#contacto"
          class="inline-flex items-center justify-center px-8 py-3.5 rounded-lg bg-primary text-white text-base font-semibold
                 hover:bg-primary-light active:scale-[0.98] transition-all duration-200 shadow-lg shadow-primary/20 hover:shadow-xl hover:shadow-primary/30"
        >
          Solicitar consulta
          <svg class="ml-2 w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
          </svg>
        </a>
        <a
          href="#servicios"
          class="inline-flex items-center justify-center px-8 py-3.5 rounded-lg border border-border bg-white text-foreground text-base font-medium
                 hover:bg-muted active:scale-[0.98] transition-all duration-200"
        >
          Conocer nuestros servicios
        </a>
      </div>

      <!-- Stats row -->
      <div class="mt-16 md:mt-20 grid grid-cols-3 gap-6 md:gap-12 pt-8 border-t border-border/60">
        <div>
          <p class="text-2xl md:text-3xl font-heading font-bold text-primary">+500</p>
          <p class="mt-1 text-xs md:text-sm text-muted-foreground">Casos resueltos</p>
        </div>
        <div>
          <p class="text-2xl md:text-3xl font-heading font-bold text-primary">15+</p>
          <p class="mt-1 text-xs md:text-sm text-muted-foreground">Años de experiencia</p>
        </div>
        <div>
          <p class="text-2xl md:text-3xl font-heading font-bold text-primary">98%</p>
          <p class="mt-1 text-xs md:text-sm text-muted-foreground">Clientes satisfechos</p>
        </div>
      </div>
    </div>
  </div>
</section>
